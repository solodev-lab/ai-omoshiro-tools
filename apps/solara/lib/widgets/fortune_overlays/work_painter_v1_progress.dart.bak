import 'dart:math' as math;
import 'dart:ui' as ui;
import 'package:flutter/material.dart';
import '_common.dart';

/// 仕事: ユーザーが為すべきことが順調に進む様子。
/// チェックマークが次々と灯り、前進の矢印が流れ、プログレスラインが埋まり、
/// 背景で歯車が静かに噛み合い、達成の光が上昇していく。
class WorkPainterBuilder extends FortunePainterBuilder {
  final _rng = math.Random();
  late final List<_Check> _checks;
  late final List<_Arrow> _arrows;
  late final List<_Progress> _progresses;
  late final List<_Gear> _gears;
  late final List<_RisingSpark> _sparks;
  late final List<_Sparkle> _sparkles;

  static const _checkCount = 44;
  static const _arrowCount = 14;
  static const _progressCount = 6;
  static const _gearCount = 3;
  static const _sparkCount = 55;
  static const _sparkleCount = 22;

  WorkPainterBuilder() {
    _checks = _buildChecks();
    _arrows = _buildArrows();
    _progresses = _buildProgresses();
    _gears = _buildGears();
    _sparks = _buildSparks();
    _sparkles = _buildSparkles();
  }

  @override
  CustomPainter buildPainter(double t) => _WorkPainter(
    t: t, checks: _checks, arrows: _arrows, progresses: _progresses,
    gears: _gears, sparks: _sparks, sparkles: _sparkles,
  );

  List<_Check> _buildChecks() {
    final list = <_Check>[];
    for (var i = 0; i < _checkCount; i++) {
      list.add(_Check(
        xRatio: 0.06 + _rng.nextDouble() * 0.88,
        yRatio: 0.06 + _rng.nextDouble() * 0.88,
        size: 26.0 + math.pow(_rng.nextDouble(), 1.6).toDouble() * 42.0,
        rotation: (_rng.nextDouble() - 0.5) * 0.35,
        hue: _rng.nextDouble(),
        delay: _rng.nextDouble() * 0.82,
        lifeSpan: 0.22 + _rng.nextDouble() * 0.20,
      ));
    }
    return list;
  }

  List<_Arrow> _buildArrows() {
    final list = <_Arrow>[];
    for (var i = 0; i < _arrowCount; i++) {
      // 右上方向にやや偏る角度（前進のイメージ）
      final dir = (_rng.nextDouble() - 0.5) * math.pi * 0.6 - math.pi * 0.1;
      list.add(_Arrow(
        startXRatio: -0.1 + _rng.nextDouble() * 0.4,
        startYRatio: 0.10 + _rng.nextDouble() * 0.80,
        dirAngle: dir,
        length: 0.22 + _rng.nextDouble() * 0.32,
        thickness: 2.5 + _rng.nextDouble() * 3.0,
        hue: _rng.nextDouble(),
        delay: 0.05 + _rng.nextDouble() * 0.70,
        lifeSpan: 0.35 + _rng.nextDouble() * 0.25,
      ));
    }
    return list;
  }

  List<_Progress> _buildProgresses() {
    final list = <_Progress>[];
    for (var i = 0; i < _progressCount; i++) {
      list.add(_Progress(
        yRatio: 0.12 + _rng.nextDouble() * 0.76,
        xStartRatio: 0.05 + _rng.nextDouble() * 0.15,
        xEndRatio: 0.65 + _rng.nextDouble() * 0.30,
        thickness: 2.5 + _rng.nextDouble() * 2.5,
        hue: _rng.nextDouble(),
        delay: 0.08 + _rng.nextDouble() * 0.55,
        fillDuration: 0.35 + _rng.nextDouble() * 0.20,
      ));
    }
    return list;
  }

  List<_Gear> _buildGears() {
    final list = <_Gear>[];
    final positions = <Offset>[
      const Offset(0.18, 0.22),
      const Offset(0.82, 0.35),
      const Offset(0.28, 0.82),
    ];
    for (var i = 0; i < _gearCount; i++) {
      list.add(_Gear(
        xRatio: positions[i].dx,
        yRatio: positions[i].dy,
        radius: 0.10 + _rng.nextDouble() * 0.10,
        toothCount: 10 + _rng.nextInt(6),
        rotSpeed: (0.35 + _rng.nextDouble() * 0.35) * (i.isEven ? 1 : -1),
        phase: _rng.nextDouble() * math.pi * 2,
      ));
    }
    return list;
  }

  List<_RisingSpark> _buildSparks() {
    final list = <_RisingSpark>[];
    for (var i = 0; i < _sparkCount; i++) {
      list.add(_RisingSpark(
        xRatio: _rng.nextDouble(),
        startYRatio: 0.7 + _rng.nextDouble() * 0.5,
        riseSpeed: 0.5 + _rng.nextDouble() * 0.5,
        size: 1.8 + _rng.nextDouble() * 3.8,
        wobbleAmp: 0.01 + _rng.nextDouble() * 0.025,
        wobbleSpeed: 1.5 + _rng.nextDouble() * 2.5,
        wobblePhase: _rng.nextDouble() * math.pi * 2,
        hue: _rng.nextDouble(),
        delay: _rng.nextDouble() * 0.70,
      ));
    }
    return list;
  }

  List<_Sparkle> _buildSparkles() {
    final list = <_Sparkle>[];
    for (var i = 0; i < _sparkleCount; i++) {
      list.add(_Sparkle(
        xRatio: _rng.nextDouble(),
        yRatio: _rng.nextDouble(),
        size: 8 + _rng.nextDouble() * 18,
        twinklePhase: _rng.nextDouble() * math.pi * 2,
        twinkleSpeed: 2.0 + _rng.nextDouble() * 2.5,
        delay: _rng.nextDouble() * 0.55,
      ));
    }
    return list;
  }
}

class _Check {
  final double xRatio, yRatio, size, rotation, hue, delay, lifeSpan;
  _Check({
    required this.xRatio, required this.yRatio, required this.size,
    required this.rotation, required this.hue,
    required this.delay, required this.lifeSpan,
  });
}

class _Arrow {
  final double startXRatio, startYRatio, dirAngle;
  final double length, thickness, hue, delay, lifeSpan;
  _Arrow({
    required this.startXRatio, required this.startYRatio, required this.dirAngle,
    required this.length, required this.thickness, required this.hue,
    required this.delay, required this.lifeSpan,
  });
}

class _Progress {
  final double yRatio, xStartRatio, xEndRatio, thickness, hue;
  final double delay, fillDuration;
  _Progress({
    required this.yRatio, required this.xStartRatio, required this.xEndRatio,
    required this.thickness, required this.hue,
    required this.delay, required this.fillDuration,
  });
}

class _Gear {
  final double xRatio, yRatio, radius, rotSpeed, phase;
  final int toothCount;
  _Gear({
    required this.xRatio, required this.yRatio, required this.radius,
    required this.toothCount, required this.rotSpeed, required this.phase,
  });
}

class _RisingSpark {
  final double xRatio, startYRatio, riseSpeed, size;
  final double wobbleAmp, wobbleSpeed, wobblePhase, hue, delay;
  _RisingSpark({
    required this.xRatio, required this.startYRatio, required this.riseSpeed,
    required this.size, required this.wobbleAmp, required this.wobbleSpeed,
    required this.wobblePhase, required this.hue, required this.delay,
  });
}

class _Sparkle {
  final double xRatio, yRatio, size, twinklePhase, twinkleSpeed, delay;
  _Sparkle({
    required this.xRatio, required this.yRatio, required this.size,
    required this.twinklePhase, required this.twinkleSpeed, required this.delay,
  });
}

class _WorkPainter extends CustomPainter {
  final double t;
  final List<_Check> checks;
  final List<_Arrow> arrows;
  final List<_Progress> progresses;
  final List<_Gear> gears;
  final List<_RisingSpark> sparks;
  final List<_Sparkle> sparkles;
  _WorkPainter({
    required this.t, required this.checks, required this.arrows,
    required this.progresses, required this.gears,
    required this.sparks, required this.sparkles,
  });

  // 達成感のある青緑〜ゴールド
  static const _mint = Color(0xFF6BE4B0);
  static const _teal = Color(0xFF3FC8C0);
  static const _sky = Color(0xFF8AD5FF);
  static const _gold = Color(0xFFFFD866);
  static const _amber = Color(0xFFFFB248);

  Color _hueColor(double h) {
    if (h < 0.28) return Color.lerp(_mint, _teal, h / 0.28)!;
    if (h < 0.55) return Color.lerp(_teal, _sky, (h - 0.28) / 0.27)!;
    if (h < 0.80) return Color.lerp(_sky, _gold, (h - 0.55) / 0.25)!;
    return Color.lerp(_gold, _amber, (h - 0.80) / 0.20)!;
  }

  @override
  void paint(Canvas canvas, Size size) {
    // 背景: 朝の清々しい空気感、上→下で空色〜ミントグリーン
    final bgAlpha = stageAlpha(t, fadeIn: 0.10, hold: 0.62, fadeOut: 0.28);
    if (bgAlpha > 0) {
      canvas.drawRect(Offset.zero & size, Paint()
        ..shader = ui.Gradient.linear(
          Offset(size.width / 2, 0),
          Offset(size.width / 2, size.height),
          [
            Color.fromRGBO(180, 220, 255, 0.35 * bgAlpha),
            Color.fromRGBO(140, 220, 200, 0.28 * bgAlpha),
            Color.fromRGBO(90, 170, 160, 0.18 * bgAlpha),
            const Color(0x00000000),
          ],
          [0.0, 0.35, 0.75, 1.0],
        ));
    }

    // 歯車（奥、静かに回転）
    for (final g in gears) { _drawGear(canvas, g, size, bgAlpha); }

    // 上昇する光の粒
    for (final sp in sparks) { _drawRisingSpark(canvas, sp, size); }

    // プログレスライン
    for (final p in progresses) { _drawProgress(canvas, p, size); }

    // 光の矢印（前進）
    for (final a in arrows) { _drawArrow(canvas, a, size); }

    // チェックマーク（達成の灯り）
    for (final c in checks) { _drawCheck(canvas, c, size); }

    // スパークル（きらめき）
    for (final s in sparkles) { _drawSparkle(canvas, s, size); }
  }

  // ─── 歯車（背景で噛み合って回る）────────────
  void _drawGear(Canvas canvas, _Gear g, Size size, double bgAlpha) {
    if (bgAlpha <= 0) return;
    final r = g.radius * size.width;
    final cx = size.width * g.xRatio;
    final cy = size.height * g.yRatio;
    final rot = g.phase + t * g.rotSpeed * math.pi * 2;
    final innerR = r * 0.55;
    final toothDepth = r * 0.18;

    canvas.save();
    canvas.translate(cx, cy);
    canvas.rotate(rot);

    // 歯車のパス
    final path = Path();
    final n = g.toothCount;
    for (var i = 0; i < n * 2; i++) {
      final a = (i / (n * 2)) * math.pi * 2;
      final rr = (i.isEven) ? r : r - toothDepth;
      final px = math.cos(a) * rr;
      final py = math.sin(a) * rr;
      if (i == 0) {
        path.moveTo(px, py);
      } else {
        path.lineTo(px, py);
      }
    }
    path.close();

    // 本体（薄く）
    canvas.drawPath(path, Paint()
      ..color = _teal.withValues(alpha: 0.12 * bgAlpha)
      ..blendMode = BlendMode.plus);
    // 外縁
    canvas.drawPath(path, Paint()
      ..style = PaintingStyle.stroke
      ..strokeWidth = math.max(1.0, r * 0.025)
      ..color = _teal.withValues(alpha: 0.40 * bgAlpha)
      ..blendMode = BlendMode.plus);
    // 中心穴
    canvas.drawCircle(Offset.zero, innerR * 0.35, Paint()
      ..style = PaintingStyle.stroke
      ..strokeWidth = math.max(1.0, r * 0.025)
      ..color = _teal.withValues(alpha: 0.50 * bgAlpha)
      ..blendMode = BlendMode.plus);
    canvas.drawCircle(Offset.zero, innerR * 0.35, Paint()
      ..color = _sky.withValues(alpha: 0.10 * bgAlpha));
    // スポーク
    final spokeCount = 4;
    final spokePaint = Paint()
      ..strokeWidth = math.max(1.0, r * 0.025)
      ..color = _teal.withValues(alpha: 0.35 * bgAlpha)
      ..strokeCap = StrokeCap.round
      ..blendMode = BlendMode.plus;
    for (var i = 0; i < spokeCount; i++) {
      final a = (i / spokeCount) * math.pi * 2;
      final p0 = Offset(math.cos(a) * innerR * 0.38, math.sin(a) * innerR * 0.38);
      final p1 = Offset(math.cos(a) * innerR * 0.92, math.sin(a) * innerR * 0.92);
      canvas.drawLine(p0, p1, spokePaint);
    }

    canvas.restore();
  }

  // ─── チェックマーク（達成の灯り）──────────────
  void _drawCheck(Canvas canvas, _Check c, Size size) {
    final localT = t - c.delay;
    if (localT <= 0 || localT >= c.lifeSpan) return;
    final lt = (localT / c.lifeSpan).clamp(0.0, 1.0);
    final alpha = stageAlpha(lt, fadeIn: 0.20, hold: 0.30, fadeOut: 0.50);
    if (alpha <= 0) return;

    final pos = Offset(size.width * c.xRatio, size.height * c.yRatio);
    final color = _hueColor(c.hue);

    // ポップインスケール
    final scaleIn = easeOutBack((lt / 0.25).clamp(0.0, 1.0));
    // 後半にじわっと膨張
    final scaleLate = 1.0 + (lt > 0.55 ? (lt - 0.55) * 0.2 : 0.0);
    final scale = scaleIn * scaleLate;

    final s = c.size * scale;

    canvas.save();
    canvas.translate(pos.dx, pos.dy);
    canvas.rotate(c.rotation);

    // グロー
    canvas.drawCircle(Offset.zero, s * 0.85, Paint()
      ..shader = ui.Gradient.radial(Offset.zero, s * 0.85, [
        color.withValues(alpha: 0.55 * alpha),
        color.withValues(alpha: 0.20 * alpha),
        const Color(0x00000000),
      ], [0.0, 0.55, 1.0])
      ..blendMode = BlendMode.plus);

    // チェックマーク本体
    final path = Path()
      ..moveTo(-s * 0.45, s * 0.02)
      ..lineTo(-s * 0.10, s * 0.35)
      ..lineTo(s * 0.45, -s * 0.35);

    // 外側ストローク（太めのカラー）
    canvas.drawPath(path, Paint()
      ..style = PaintingStyle.stroke
      ..strokeWidth = math.max(3.0, s * 0.14)
      ..strokeCap = StrokeCap.round
      ..strokeJoin = StrokeJoin.round
      ..color = color.withValues(alpha: alpha)
      ..blendMode = BlendMode.plus);

    // 内側ストローク（白くて細い）
    canvas.drawPath(path, Paint()
      ..style = PaintingStyle.stroke
      ..strokeWidth = math.max(1.5, s * 0.07)
      ..strokeCap = StrokeCap.round
      ..strokeJoin = StrokeJoin.round
      ..color = Colors.white.withValues(alpha: 0.95 * alpha)
      ..blendMode = BlendMode.plus);

    canvas.restore();
  }

  // ─── 光の矢印（前進）─────────────────────────
  void _drawArrow(Canvas canvas, _Arrow ar, Size size) {
    final localT = t - ar.delay;
    if (localT <= 0 || localT >= ar.lifeSpan) return;
    final lt = (localT / ar.lifeSpan).clamp(0.0, 1.0);
    final alpha = stageAlpha(lt, fadeIn: 0.18, hold: 0.45, fadeOut: 0.37);
    if (alpha <= 0) return;

    // 矢印が全距離を進行する
    final fullDist = size.width * (1.2 + ar.length);
    final travel = fullDist * easeInOutQuad(lt);
    final sx = size.width * ar.startXRatio;
    final sy = size.height * ar.startYRatio;
    final dx = math.cos(ar.dirAngle);
    final dy = math.sin(ar.dirAngle);

    final headX = sx + dx * travel;
    final headY = sy + dy * travel;
    final tailLen = ar.length * size.width;
    final tailX = headX - dx * tailLen;
    final tailY = headY - dy * tailLen;

    final head = Offset(headX, headY);
    final tail = Offset(tailX, tailY);
    final color = _hueColor(ar.hue);

    // 尾の光（グラデ太め）
    canvas.drawLine(tail, head, Paint()
      ..strokeWidth = ar.thickness * 4.0
      ..shader = ui.Gradient.linear(tail, head, [
        color.withValues(alpha: 0.0),
        color.withValues(alpha: 0.40 * alpha),
        color.withValues(alpha: 0.70 * alpha),
      ], [0.0, 0.4, 1.0])
      ..blendMode = BlendMode.plus
      ..strokeCap = StrokeCap.round);
    // 中心の細い光
    canvas.drawLine(tail, head, Paint()
      ..strokeWidth = ar.thickness * 1.2
      ..shader = ui.Gradient.linear(tail, head, [
        color.withValues(alpha: 0.0),
        Colors.white.withValues(alpha: 0.55 * alpha),
        Colors.white.withValues(alpha: 0.95 * alpha),
      ], [0.0, 0.6, 1.0])
      ..blendMode = BlendMode.plus
      ..strokeCap = StrokeCap.round);

    // 矢尻（三角形）
    final normalX = -dy;
    final normalY = dx;
    final wingLen = ar.thickness * 6.0;
    final wingBackLen = ar.thickness * 7.0;
    final back = Offset(headX - dx * wingBackLen, headY - dy * wingBackLen);
    final wingL = Offset(back.dx + normalX * wingLen, back.dy + normalY * wingLen);
    final wingR = Offset(back.dx - normalX * wingLen, back.dy - normalY * wingLen);

    final headPath = Path()
      ..moveTo(head.dx, head.dy)
      ..lineTo(wingL.dx, wingL.dy)
      ..lineTo(wingR.dx, wingR.dy)
      ..close();
    canvas.drawPath(headPath, Paint()
      ..color = color.withValues(alpha: 0.85 * alpha)
      ..blendMode = BlendMode.plus);
    canvas.drawPath(headPath, Paint()
      ..style = PaintingStyle.stroke
      ..strokeWidth = math.max(1.0, ar.thickness * 0.5)
      ..color = Colors.white.withValues(alpha: 0.85 * alpha)
      ..blendMode = BlendMode.plus
      ..strokeJoin = StrokeJoin.round);

    // 先端グロー
    canvas.drawCircle(head, ar.thickness * 3.5, Paint()
      ..shader = ui.Gradient.radial(head, ar.thickness * 3.5, [
        Colors.white.withValues(alpha: 0.85 * alpha),
        color.withValues(alpha: 0.35 * alpha),
        const Color(0x00000000),
      ], [0.0, 0.4, 1.0])
      ..blendMode = BlendMode.plus);
  }

  // ─── プログレスライン ────────────────────────
  void _drawProgress(Canvas canvas, _Progress p, Size size) {
    final localT = t - p.delay;
    if (localT <= 0) return;
    // 埋まる期間 + その後の残光期間
    final fullDuration = p.fillDuration + 0.20;
    if (localT >= fullDuration) return;
    final lt = (localT / fullDuration).clamp(0.0, 1.0);
    final alpha = stageAlpha(lt, fadeIn: 0.10, hold: 0.60, fadeOut: 0.30);
    if (alpha <= 0) return;

    // 0→1 まで埋まる進捗率
    final fillT = (localT / p.fillDuration).clamp(0.0, 1.0);
    final fill = easeInOutQuad(fillT);

    final y = size.height * p.yRatio;
    final xStart = size.width * p.xStartRatio;
    final xEnd = size.width * p.xEndRatio;
    final currentEnd = xStart + (xEnd - xStart) * fill;

    final color = _hueColor(p.hue);

    // 背景トラック（薄い線）
    canvas.drawLine(
      Offset(xStart, y), Offset(xEnd, y),
      Paint()
        ..strokeWidth = p.thickness * 0.8
        ..color = color.withValues(alpha: 0.22 * alpha)
        ..strokeCap = StrokeCap.round
        ..blendMode = BlendMode.plus,
    );

    // 埋まった部分（グロー）
    canvas.drawLine(
      Offset(xStart, y), Offset(currentEnd, y),
      Paint()
        ..strokeWidth = p.thickness * 3.0
        ..shader = ui.Gradient.linear(
          Offset(xStart, y), Offset(currentEnd, y),
          [
            color.withValues(alpha: 0.30 * alpha),
            color.withValues(alpha: 0.80 * alpha),
          ],
          [0.0, 1.0],
        )
        ..strokeCap = StrokeCap.round
        ..blendMode = BlendMode.plus,
    );
    // 中央白コア
    canvas.drawLine(
      Offset(xStart, y), Offset(currentEnd, y),
      Paint()
        ..strokeWidth = p.thickness * 1.2
        ..shader = ui.Gradient.linear(
          Offset(xStart, y), Offset(currentEnd, y),
          [
            Colors.white.withValues(alpha: 0.45 * alpha),
            Colors.white.withValues(alpha: 0.95 * alpha),
          ],
          [0.0, 1.0],
        )
        ..strokeCap = StrokeCap.round
        ..blendMode = BlendMode.plus,
    );

    // 埋まり中の先端ヘッド
    if (fillT < 1.0) {
      canvas.drawCircle(
        Offset(currentEnd, y), p.thickness * 2.8,
        Paint()
          ..shader = ui.Gradient.radial(
            Offset(currentEnd, y), p.thickness * 2.8,
            [
              Colors.white.withValues(alpha: 0.95 * alpha),
              color.withValues(alpha: 0.45 * alpha),
              const Color(0x00000000),
            ],
            [0.0, 0.4, 1.0],
          )
          ..blendMode = BlendMode.plus,
      );
    } else {
      // 完了フラッシュ（終点で弾ける）
      final afterFill = ((localT - p.fillDuration) / 0.20).clamp(0.0, 1.0);
      final burst = 1.0 - afterFill;
      final br = p.thickness * (6.0 + afterFill * 18.0);
      canvas.drawCircle(Offset(xEnd, y), br, Paint()
        ..shader = ui.Gradient.radial(Offset(xEnd, y), br, [
          Colors.white.withValues(alpha: 0.85 * burst * alpha),
          color.withValues(alpha: 0.45 * burst * alpha),
          const Color(0x00000000),
        ], [0.0, 0.4, 1.0])
        ..blendMode = BlendMode.plus);
      canvas.drawCircle(Offset(xEnd, y), br * 0.6, Paint()
        ..style = PaintingStyle.stroke
        ..strokeWidth = math.max(1.2, p.thickness * 0.5)
        ..color = Colors.white.withValues(alpha: 0.7 * burst * alpha)
        ..blendMode = BlendMode.plus);
    }
  }

  // ─── 上昇する光の粒 ──────────────────────────
  void _drawRisingSpark(Canvas canvas, _RisingSpark sp, Size size) {
    final lt = ((t - sp.delay) / (1.0 - sp.delay)).clamp(0.0, 1.0);
    if (lt <= 0) return;
    final alpha = stageAlpha(lt, fadeIn: 0.15, hold: 0.55, fadeOut: 0.30);
    if (alpha <= 0) return;

    final travel = size.height * 1.25 * sp.riseSpeed * lt;
    final startY = size.height * sp.startYRatio;
    final y = startY - travel;
    if (y < -20) return;

    final wobble = math.sin(sp.wobblePhase + lt * sp.wobbleSpeed * math.pi * 2)
        * sp.wobbleAmp * size.width;
    final x = sp.xRatio * size.width + wobble;
    final pos = Offset(x, y);

    final color = _hueColor(sp.hue);
    canvas.drawCircle(pos, sp.size * 2.2, Paint()
      ..shader = ui.Gradient.radial(pos, sp.size * 2.2, [
        color.withValues(alpha: 0.7 * alpha),
        color.withValues(alpha: 0.22 * alpha),
        const Color(0x00000000),
      ], [0.0, 0.5, 1.0])
      ..blendMode = BlendMode.plus);
    canvas.drawCircle(pos, sp.size * 0.7, Paint()
      ..color = Colors.white.withValues(alpha: alpha));
  }

  // ─── スパークル ──────────────────────────────
  void _drawSparkle(Canvas canvas, _Sparkle sp, Size size) {
    final lt = ((t - sp.delay) / (1.0 - sp.delay)).clamp(0.0, 1.0);
    if (lt <= 0) return;
    final fadeEnv = stageAlpha(lt, fadeIn: 0.18, hold: 0.55, fadeOut: 0.27);
    if (fadeEnv <= 0) return;

    final pos = Offset(size.width * sp.xRatio, size.height * sp.yRatio);
    final tw = (math.sin(sp.twinklePhase + lt * sp.twinkleSpeed * math.pi * 2) + 1) / 2;
    final alpha = fadeEnv * (0.35 + tw * 0.65);
    const color = Color(0xFFFFF2C8);
    final size2 = sp.size * (0.7 + tw * 0.6);

    canvas.save();
    canvas.translate(pos.dx, pos.dy);
    canvas.drawCircle(Offset.zero, size2 * 0.7, Paint()
      ..shader = ui.Gradient.radial(Offset.zero, size2 * 0.7, [
        color.withValues(alpha: 0.55 * alpha),
        color.withValues(alpha: 0.18 * alpha),
        const Color(0x00000000),
      ], [0.0, 0.5, 1.0])
      ..blendMode = BlendMode.plus);
    final starPaint = Paint()..color = color.withValues(alpha: alpha)..blendMode = BlendMode.plus;
    canvas.drawPath(Path()
      ..moveTo(0, -size2 * 0.5)
      ..quadraticBezierTo(size2 * 0.04, 0, 0, size2 * 0.5)
      ..quadraticBezierTo(-size2 * 0.04, 0, 0, -size2 * 0.5)
      ..close(), starPaint);
    canvas.drawPath(Path()
      ..moveTo(-size2 * 0.5, 0)
      ..quadraticBezierTo(0, size2 * 0.04, size2 * 0.5, 0)
      ..quadraticBezierTo(0, -size2 * 0.04, -size2 * 0.5, 0)
      ..close(), starPaint);
    canvas.drawCircle(Offset.zero, size2 * 0.06, Paint()..color = Color.fromRGBO(255, 255, 255, alpha));
    canvas.restore();
  }

  @override
  bool shouldRepaint(covariant _WorkPainter old) => old.t != t;
}
