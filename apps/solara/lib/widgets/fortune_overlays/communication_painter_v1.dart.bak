import 'dart:math' as math;
import 'dart:ui' as ui;
import 'package:flutter/material.dart';
import '_common.dart';

/// 話す: 音符ペアが触れ合って光りながら、水平ストリームが走り、
/// 同時に無秩序な音符・光の粒がランダムに現れては消える混沌とした賑わい。
class CommunicationPainterBuilder extends FortunePainterBuilder {
  final _rng = math.Random();
  late final List<_NotePair> _pairs;
  late final List<_Note> _chaoticNotes;
  late final List<_Stream> _streams;
  late final List<_Spark> _sparks;
  late final List<_Sparkle> _sparkles;

  static const _pairCount = 10;
  static const _chaoticNoteCount = 28;
  static const _streamCount = 6;
  static const _sparkCount = 60;
  static const _sparkleCount = 22;

  CommunicationPainterBuilder() {
    _pairs = _buildPairs();
    _chaoticNotes = _buildChaoticNotes();
    _streams = _buildStreams();
    _sparks = _buildSparks();
    _sparkles = _buildSparkles();
  }

  @override
  CustomPainter buildPainter(double t) => _CommunicationPainter(
    t: t, pairs: _pairs, chaoticNotes: _chaoticNotes,
    streams: _streams, sparks: _sparks, sparkles: _sparkles,
  );

  List<_NotePair> _buildPairs() {
    const symbolsA = ['♪', '♫', '♩', '♬'];
    const symbolsB = ['♩', '♪', '♬', '♫'];
    final list = <_NotePair>[];
    for (var i = 0; i < _pairCount; i++) {
      final sizeA = 26.0 + math.pow(_rng.nextDouble(), 1.6).toDouble() * 42.0;
      final sizeB = sizeA * (0.82 + _rng.nextDouble() * 0.30);
      list.add(_NotePair(
        baseX: 0.15 + _rng.nextDouble() * 0.70,
        baseY: 0.15 + _rng.nextDouble() * 0.70,
        // 2D wander: x/y それぞれ独立した正弦波で画面内を自由に飛び回る
        wanderAmpX: 0.15 + _rng.nextDouble() * 0.25,
        wanderAmpY: 0.15 + _rng.nextDouble() * 0.25,
        wanderSpeedX: (0.6 + _rng.nextDouble() * 1.1) * (_rng.nextBool() ? 1 : -1),
        wanderSpeedY: (0.6 + _rng.nextDouble() * 1.1) * (_rng.nextBool() ? 1 : -1),
        wanderPhaseX: _rng.nextDouble() * math.pi * 2,
        wanderPhaseY: _rng.nextDouble() * math.pi * 2,
        orbitRadius: 0.06 + _rng.nextDouble() * 0.09,
        orbitSpeed: (1.8 + _rng.nextDouble() * 1.6) * (_rng.nextBool() ? 1 : -1),
        orbitPhase: _rng.nextDouble() * math.pi * 2,
        symbolA: symbolsA[_rng.nextInt(symbolsA.length)],
        symbolB: symbolsB[_rng.nextInt(symbolsB.length)],
        sizeA: sizeA, sizeB: sizeB,
        hueA: _rng.nextDouble(), hueB: _rng.nextDouble(),
        rotA: (_rng.nextDouble() - 0.5) * 0.5,
        rotB: (_rng.nextDouble() - 0.5) * 0.5,
        rotSpeedA: (_rng.nextDouble() - 0.5) * 1.2,
        rotSpeedB: (_rng.nextDouble() - 0.5) * 1.2,
        delay: _rng.nextDouble() * 0.45,
      ));
    }
    return list;
  }

  List<_Note> _buildChaoticNotes() {
    const symbols = ['♪', '♫', '♩', '♬', '♭', '♯'];
    final list = <_Note>[];
    for (var i = 0; i < _chaoticNoteCount; i++) {
      final stays = _rng.nextDouble() < 0.30;
      final angle = _rng.nextDouble() * math.pi * 2;
      final speed = stays ? 0.0 : 0.02 + _rng.nextDouble() * 0.08;
      list.add(_Note(
        symbol: symbols[_rng.nextInt(symbols.length)],
        xRatio: 0.05 + _rng.nextDouble() * 0.90,
        yRatio: 0.05 + _rng.nextDouble() * 0.90,
        vx: math.cos(angle) * speed,
        vy: math.sin(angle) * speed,
        size: 18.0 + math.pow(_rng.nextDouble(), 1.7).toDouble() * 44.0,
        rotation: (_rng.nextDouble() - 0.5) * 0.6,
        rotSpeed: (_rng.nextDouble() - 0.5) * 1.4,
        hue: _rng.nextDouble(),
        delay: _rng.nextDouble() * 0.80,
        lifeSpan: 0.15 + _rng.nextDouble() * 0.25,
      ));
    }
    return list;
  }

  List<_Stream> _buildStreams() {
    final list = <_Stream>[];
    for (var i = 0; i < _streamCount; i++) {
      final leftToRight = _rng.nextBool();
      list.add(_Stream(
        leftToRight: leftToRight,
        yRatio: 0.1 + _rng.nextDouble() * 0.80,
        thickness: 1.5 + _rng.nextDouble() * 3.5,
        curvature: (_rng.nextDouble() - 0.5) * 0.18,
        hue: _rng.nextDouble(),
        delay: 0.05 + _rng.nextDouble() * 0.55,
        lifeSpan: 0.40 + _rng.nextDouble() * 0.25,
      ));
    }
    return list;
  }

  List<_Spark> _buildSparks() {
    final list = <_Spark>[];
    for (var i = 0; i < _sparkCount; i++) {
      final angle = _rng.nextDouble() * math.pi * 2;
      final speed = _rng.nextDouble() < 0.35 ? 0.0 : 0.02 + _rng.nextDouble() * 0.10;
      list.add(_Spark(
        xRatio: _rng.nextDouble(),
        yRatio: _rng.nextDouble(),
        vx: math.cos(angle) * speed,
        vy: math.sin(angle) * speed,
        size: 2.0 + _rng.nextDouble() * 5.0,
        hue: _rng.nextDouble(),
        delay: _rng.nextDouble() * 0.80,
        lifeSpan: 0.10 + _rng.nextDouble() * 0.22,
      ));
    }
    return list;
  }

  List<_Sparkle> _buildSparkles() {
    final list = <_Sparkle>[];
    for (var i = 0; i < _sparkleCount; i++) {
      list.add(_Sparkle(
        xRatio: _rng.nextDouble(),
        yRatio: _rng.nextDouble(),
        size: 9 + _rng.nextDouble() * 22,
        twinklePhase: _rng.nextDouble() * math.pi * 2,
        twinkleSpeed: 2.5 + _rng.nextDouble() * 2.5,
        hue: _rng.nextDouble(),
        delay: _rng.nextDouble() * 0.65,
        lifeSpan: 0.15 + _rng.nextDouble() * 0.25,
      ));
    }
    return list;
  }
}

class _NotePair {
  final double baseX, baseY;
  final double wanderAmpX, wanderAmpY;
  final double wanderSpeedX, wanderSpeedY;
  final double wanderPhaseX, wanderPhaseY;
  final double orbitRadius, orbitSpeed, orbitPhase;
  final String symbolA, symbolB;
  final double sizeA, sizeB, hueA, hueB;
  final double rotA, rotB, rotSpeedA, rotSpeedB;
  final double delay;
  _NotePair({
    required this.baseX, required this.baseY,
    required this.wanderAmpX, required this.wanderAmpY,
    required this.wanderSpeedX, required this.wanderSpeedY,
    required this.wanderPhaseX, required this.wanderPhaseY,
    required this.orbitRadius, required this.orbitSpeed, required this.orbitPhase,
    required this.symbolA, required this.symbolB,
    required this.sizeA, required this.sizeB,
    required this.hueA, required this.hueB,
    required this.rotA, required this.rotB,
    required this.rotSpeedA, required this.rotSpeedB,
    required this.delay,
  });
}

class _Note {
  final String symbol;
  final double xRatio, yRatio, vx, vy;
  final double size, rotation, rotSpeed, hue, delay, lifeSpan;
  _Note({
    required this.symbol,
    required this.xRatio, required this.yRatio,
    required this.vx, required this.vy,
    required this.size, required this.rotation, required this.rotSpeed,
    required this.hue, required this.delay, required this.lifeSpan,
  });
}

class _Stream {
  final bool leftToRight;
  final double yRatio, thickness, curvature, hue, delay, lifeSpan;
  _Stream({
    required this.leftToRight, required this.yRatio, required this.thickness,
    required this.curvature, required this.hue,
    required this.delay, required this.lifeSpan,
  });
}

class _Spark {
  final double xRatio, yRatio, vx, vy;
  final double size, hue, delay, lifeSpan;
  _Spark({
    required this.xRatio, required this.yRatio,
    required this.vx, required this.vy,
    required this.size, required this.hue, required this.delay, required this.lifeSpan,
  });
}

class _Sparkle {
  final double xRatio, yRatio, size, twinklePhase, twinkleSpeed, hue, delay, lifeSpan;
  _Sparkle({
    required this.xRatio, required this.yRatio, required this.size,
    required this.twinklePhase, required this.twinkleSpeed,
    required this.hue, required this.delay, required this.lifeSpan,
  });
}

class _CommunicationPainter extends CustomPainter {
  final double t;
  final List<_NotePair> pairs;
  final List<_Note> chaoticNotes;
  final List<_Stream> streams;
  final List<_Spark> sparks;
  final List<_Sparkle> sparkles;
  _CommunicationPainter({
    required this.t, required this.pairs, required this.chaoticNotes,
    required this.streams, required this.sparks, required this.sparkles,
  });

  static const _lavender = Color(0xFFB088FF);
  static const _blue = Color(0xFF8AB5FF);
  static const _violet = Color(0xFFD8BFFF);
  static const _cyan = Color(0xFFA8DFFF);
  static const _pink = Color(0xFFFFB0D8);
  static const _mint = Color(0xFFA8F0E0);

  Color _hueColor(double h) {
    if (h < 0.2) return Color.lerp(_lavender, _blue, h * 5)!;
    if (h < 0.4) return Color.lerp(_blue, _cyan, (h - 0.2) * 5)!;
    if (h < 0.6) return Color.lerp(_cyan, _mint, (h - 0.4) * 5)!;
    if (h < 0.8) return Color.lerp(_mint, _violet, (h - 0.6) * 5)!;
    return Color.lerp(_violet, _pink, (h - 0.8) * 5)!;
  }

  @override
  void paint(Canvas canvas, Size size) {
    final bgAlpha = stageAlpha(t, fadeIn: 0.12, hold: 0.58, fadeOut: 0.30);
    if (bgAlpha > 0) {
      canvas.drawRect(Offset.zero & size, Paint()
        ..shader = ui.Gradient.linear(
          Offset(0, 0), Offset(size.width, size.height),
          [
            Color.fromRGBO(180, 150, 255, 0.30 * bgAlpha),
            Color.fromRGBO(130, 170, 240, 0.20 * bgAlpha),
            Color.fromRGBO(30, 15, 50, 0.13 * bgAlpha),
            const Color(0x00000000),
          ],
          [0.0, 0.35, 0.75, 1.0],
        ));
    }

    // 電子スパーク（奥）
    for (final sp in sparks) { _drawSpark(canvas, sp, size); }

    // 水平ストリーム
    for (final s in streams) { _drawStream(canvas, s, size); }

    // ペア音符（衝突フラッシュ含む）
    for (final pair in pairs) { _drawPair(canvas, pair, size); }

    // 無秩序音符
    for (final n in chaoticNotes) { _drawChaoticNote(canvas, n, size); }

    // 大きなスパークル
    for (final s in sparkles) { _drawSparkle(canvas, s, size); }
  }

  // ─── ペア音符 ─────────────────────────────────
  void _drawPair(Canvas canvas, _NotePair pair, Size size) {
    final lt = ((t - pair.delay) / (1.0 - pair.delay)).clamp(0.0, 1.0);
    if (lt <= 0) return;
    final alpha = stageAlpha(lt, fadeIn: 0.12, hold: 0.60, fadeOut: 0.28);
    if (alpha <= 0) return;

    // 2D wander: 画面内を自由に飛び回る
    final wx = math.sin(pair.wanderPhaseX + lt * pair.wanderSpeedX * math.pi * 2) * pair.wanderAmpX;
    final wy = math.sin(pair.wanderPhaseY + lt * pair.wanderSpeedY * math.pi * 2) * pair.wanderAmpY;
    final centerX = size.width * (pair.baseX + wx);
    final centerY = size.height * (pair.baseY + wy);

    final angle = pair.orbitPhase + lt * pair.orbitSpeed * math.pi * 2;
    final radius = pair.orbitRadius * size.width;
    final offsetX = math.cos(angle) * radius;
    final offsetY = math.sin(angle) * radius * 0.8; // より円に近い軌道

    final posA = Offset(centerX + offsetX, centerY + offsetY);
    final posB = Offset(centerX - offsetX, centerY - offsetY);

    final proximity = 1.0 - math.cos(angle).abs();
    if (proximity > 0.85) {
      _drawCollisionFlash(canvas, Offset(centerX, centerY),
          (proximity - 0.85) / 0.15, pair, alpha);
    }

    _drawOrbitTrail(canvas, centerX, centerY, radius, alpha);

    _drawPairNote(canvas, posA, pair.symbolA, pair.sizeA, pair.hueA,
        pair.rotA + pair.rotSpeedA * lt, lt, alpha);
    _drawPairNote(canvas, posB, pair.symbolB, pair.sizeB, pair.hueB,
        pair.rotB + pair.rotSpeedB * lt, lt, alpha);
  }

  void _drawOrbitTrail(
      Canvas canvas, double cx, double cy, double radius, double alpha) {
    canvas.drawOval(
      Rect.fromCenter(center: Offset(cx, cy), width: radius * 2, height: radius * 0.7),
      Paint()
        ..style = PaintingStyle.stroke
        ..strokeWidth = 0.8
        ..color = Color.fromRGBO(210, 220, 255, 0.10 * alpha)
        ..blendMode = BlendMode.plus,
    );
  }

  void _drawCollisionFlash(
      Canvas canvas, Offset center, double intensity, _NotePair pair, double alpha) {
    final avgSize = (pair.sizeA + pair.sizeB) * 0.5;
    final r = avgSize * (0.7 + intensity * 0.9);
    final a = alpha * intensity;
    final colorA = _hueColor(pair.hueA);
    final colorB = _hueColor(pair.hueB);
    final blend = Color.lerp(colorA, colorB, 0.5)!;

    canvas.drawCircle(center, r * 1.4, Paint()
      ..shader = ui.Gradient.radial(center, r * 1.4, [
        blend.withValues(alpha: 0.55 * a),
        blend.withValues(alpha: 0.18 * a),
        const Color(0x00000000),
      ], [0.0, 0.55, 1.0])
      ..blendMode = BlendMode.plus);

    canvas.drawCircle(center, r * (0.7 + intensity * 0.35), Paint()
      ..style = PaintingStyle.stroke
      ..strokeWidth = math.max(1.2, avgSize * 0.05)
      ..color = Color.fromRGBO(255, 255, 255, 0.85 * a)
      ..blendMode = BlendMode.plus);

    canvas.drawCircle(center, avgSize * 0.18 * intensity, Paint()
      ..color = Color.fromRGBO(255, 255, 255, 0.90 * a)
      ..blendMode = BlendMode.plus);

    final spikePaint = Paint()
      ..color = Color.fromRGBO(255, 255, 255, 0.70 * a)
      ..strokeWidth = math.max(1.0, avgSize * 0.03)
      ..strokeCap = StrokeCap.round
      ..blendMode = BlendMode.plus;
    final spike = avgSize * (0.5 + intensity * 0.6);
    canvas.drawLine(center.translate(-spike, 0), center.translate(spike, 0), spikePaint);
    canvas.drawLine(center.translate(0, -spike), center.translate(0, spike), spikePaint);
    final d = spike * 0.65;
    canvas.drawLine(center.translate(-d, -d), center.translate(d, d), spikePaint);
    canvas.drawLine(center.translate(-d, d), center.translate(d, -d), spikePaint);
  }

  void _drawPairNote(Canvas canvas, Offset pos, String symbol, double s,
      double hue, double rot, double lt, double alpha) {
    final scale = easeOutBack((lt / 0.22).clamp(0.0, 1.0)) * (0.9 + lt * 0.15);
    _paintNote(canvas, pos, symbol, s, hue, rot, scale, alpha);
  }

  // ─── 無秩序音符 ───────────────────────────────
  void _drawChaoticNote(Canvas canvas, _Note n, Size size) {
    final localT = t - n.delay;
    if (localT <= 0 || localT >= n.lifeSpan) return;
    final lt = (localT / n.lifeSpan).clamp(0.0, 1.0);
    final alpha = stageAlpha(lt, fadeIn: 0.30, hold: 0.25, fadeOut: 0.45);
    if (alpha <= 0) return;

    final x = size.width * n.xRatio + n.vx * size.width * localT;
    final y = size.height * n.yRatio + n.vy * size.height * localT;

    final scaleIn = easeOutBack((lt / 0.30).clamp(0.0, 1.0));
    final scale = scaleIn * (1.0 - (lt > 0.55 ? (lt - 0.55) * 0.3 : 0.0));
    final rot = n.rotation + n.rotSpeed * localT;

    _paintNote(canvas, Offset(x, y), n.symbol, n.size, n.hue, rot, scale, alpha);
  }

  // 共通ノート描画
  void _paintNote(Canvas canvas, Offset pos, String symbol, double s,
      double hue, double rot, double scale, double alpha) {
    final color = _hueColor(hue);

    canvas.save();
    canvas.translate(pos.dx, pos.dy);
    canvas.rotate(rot);
    canvas.scale(scale);

    canvas.drawCircle(Offset.zero, s * 0.8, Paint()
      ..shader = ui.Gradient.radial(Offset.zero, s * 0.8, [
        color.withValues(alpha: 0.55 * alpha),
        color.withValues(alpha: 0.18 * alpha),
        const Color(0x00000000),
      ], [0.0, 0.55, 1.0])
      ..blendMode = BlendMode.plus);

    final notePaint = Paint()
      ..shader = ui.Gradient.linear(
        Offset(0, -s * 0.5), Offset(0, s * 0.5),
        [
          const Color(0xFFFFFFFF).withValues(alpha: alpha),
          color.withValues(alpha: alpha),
          Color.lerp(color, Colors.black, 0.4)!.withValues(alpha: 0.85 * alpha),
        ],
        [0.0, 0.5, 1.0],
      );

    final textStyle = TextStyle(
      fontSize: s,
      foreground: notePaint,
      height: 1.0,
      shadows: [
        Shadow(
          color: Colors.white.withValues(alpha: 0.35 * alpha),
          blurRadius: 0,
          offset: const Offset(0, 0),
        ),
      ],
    );

    final tp = TextPainter(
      text: TextSpan(text: symbol, style: textStyle),
      textDirection: TextDirection.ltr,
      textAlign: TextAlign.center,
    );
    tp.layout();
    tp.paint(canvas, Offset(-tp.width / 2, -tp.height / 2));

    final outlinePaint = Paint()
      ..style = PaintingStyle.stroke
      ..strokeWidth = math.max(0.6, s * 0.04)
      ..color = Color.fromRGBO(255, 255, 255, 0.55 * alpha);
    final tpOutline = TextPainter(
      text: TextSpan(text: symbol, style: TextStyle(
        fontSize: s, height: 1.0, foreground: outlinePaint,
      )),
      textDirection: TextDirection.ltr,
    );
    tpOutline.layout();
    tpOutline.paint(canvas, Offset(-tpOutline.width / 2, -tpOutline.height / 2));

    canvas.restore();
  }

  // ─── 流れる光玉（しっぽなし）───────────────
  // 以前は流星のような尾付きデザインだったが、停滞や浮遊感を伴う画面には
  // 不自然なため廃止。淡い弧の道筋と、その上を滑る光玉だけで表現する。
  void _drawStream(Canvas canvas, _Stream s, Size size) {
    final localT = t - s.delay;
    if (localT <= 0 || localT >= s.lifeSpan) return;
    final lt = (localT / s.lifeSpan).clamp(0.0, 1.0);
    final alpha = stageAlpha(lt, fadeIn: 0.20, hold: 0.45, fadeOut: 0.35);
    if (alpha <= 0) return;

    final progress = easeInOutQuad(lt);
    final yBase = size.height * s.yRatio;
    final curveOffset = s.curvature * size.height * 0.30;

    // 弧のコントロールポイント
    final xStart = s.leftToRight ? -size.width * 0.15 : size.width * 1.15;
    final xEnd = s.leftToRight ? size.width * 1.15 : -size.width * 0.15;
    final midX = (xStart + xEnd) * 0.5;
    final midY = yBase + curveOffset;

    // 弧の道筋（非常に薄く）
    final pathArc = Path()
      ..moveTo(xStart, yBase)
      ..quadraticBezierTo(midX, midY, xEnd, yBase);
    final color = _hueColor(s.hue);
    canvas.drawPath(pathArc, Paint()
      ..style = PaintingStyle.stroke
      ..strokeWidth = math.max(0.8, s.thickness * 0.5)
      ..color = color.withValues(alpha: 0.16 * alpha)
      ..blendMode = BlendMode.plus);

    // 弧上の光玉位置を二次ベジェ補間で算出
    final relT = s.leftToRight ? progress : (1.0 - progress);
    final mt = 1.0 - relT;
    final bx = mt * mt * xStart + 2 * mt * relT * midX + relT * relT * xEnd;
    final by = mt * mt * yBase + 2 * mt * relT * midY + relT * relT * yBase;
    final head = Offset(bx, by);

    // 光玉の外グロー
    canvas.drawCircle(head, s.thickness * 6.0, Paint()
      ..shader = ui.Gradient.radial(head, s.thickness * 6.0, [
        color.withValues(alpha: 0.70 * alpha),
        color.withValues(alpha: 0.22 * alpha),
        const Color(0x00000000),
      ], [0.0, 0.5, 1.0])
      ..blendMode = BlendMode.plus);

    // コアグロー
    canvas.drawCircle(head, s.thickness * 2.5, Paint()
      ..shader = ui.Gradient.radial(head, s.thickness * 2.5, [
        Colors.white.withValues(alpha: 0.95 * alpha),
        color.withValues(alpha: 0.50 * alpha),
        const Color(0x00000000),
      ], [0.0, 0.5, 1.0])
      ..blendMode = BlendMode.plus);

    // 白コア
    canvas.drawCircle(head, s.thickness * 0.9, Paint()
      ..color = Colors.white.withValues(alpha: alpha));
  }

  // ─── 電子スパーク ─────────────────────────────
  void _drawSpark(Canvas canvas, _Spark sp, Size size) {
    final localT = t - sp.delay;
    if (localT <= 0 || localT >= sp.lifeSpan) return;
    final lt = (localT / sp.lifeSpan).clamp(0.0, 1.0);
    final alpha = stageAlpha(lt, fadeIn: 0.25, hold: 0.30, fadeOut: 0.45);
    if (alpha <= 0) return;

    final x = size.width * sp.xRatio + sp.vx * size.width * localT;
    final y = size.height * sp.yRatio + sp.vy * size.height * localT;
    final pos = Offset(x, y);

    final color = _hueColor(sp.hue);
    final pulse = 0.7 + 0.3 * math.sin(lt * math.pi);
    final s2 = sp.size * pulse;

    canvas.drawCircle(pos, s2 * 1.8, Paint()
      ..shader = ui.Gradient.radial(pos, s2 * 1.8, [
        color.withValues(alpha: 0.60 * alpha),
        color.withValues(alpha: 0.18 * alpha),
        const Color(0x00000000),
      ], [0.0, 0.55, 1.0])
      ..blendMode = BlendMode.plus);
    canvas.drawCircle(pos, s2, Paint()
      ..color = Color.lerp(Colors.white, color, 0.25)!.withValues(alpha: alpha));
  }

  // ─── 大きめスパークル ─────────────────────────
  void _drawSparkle(Canvas canvas, _Sparkle sp, Size size) {
    final localT = t - sp.delay;
    if (localT <= 0 || localT >= sp.lifeSpan) return;
    final lt = (localT / sp.lifeSpan).clamp(0.0, 1.0);
    final fadeEnv = stageAlpha(lt, fadeIn: 0.28, hold: 0.25, fadeOut: 0.47);
    if (fadeEnv <= 0) return;

    final pos = Offset(size.width * sp.xRatio, size.height * sp.yRatio);
    final tw = (math.sin(sp.twinklePhase + lt * sp.twinkleSpeed * math.pi * 2) + 1) / 2;
    final alpha = fadeEnv * (0.40 + tw * 0.60);
    final color = _hueColor(sp.hue);
    final size2 = sp.size * (0.7 + tw * 0.6);

    canvas.save();
    canvas.translate(pos.dx, pos.dy);
    canvas.drawCircle(Offset.zero, size2 * 0.7, Paint()
      ..shader = ui.Gradient.radial(Offset.zero, size2 * 0.7, [
        color.withValues(alpha: 0.55 * alpha),
        color.withValues(alpha: 0.18 * alpha),
        const Color(0x00000000),
      ], [0.0, 0.5, 1.0])
      ..blendMode = BlendMode.plus);
    final starPaint = Paint()..color = color.withValues(alpha: alpha)..blendMode = BlendMode.plus;
    canvas.drawPath(Path()
      ..moveTo(0, -size2 * 0.5)
      ..quadraticBezierTo(size2 * 0.04, 0, 0, size2 * 0.5)
      ..quadraticBezierTo(-size2 * 0.04, 0, 0, -size2 * 0.5)
      ..close(), starPaint);
    canvas.drawPath(Path()
      ..moveTo(-size2 * 0.5, 0)
      ..quadraticBezierTo(0, size2 * 0.04, size2 * 0.5, 0)
      ..quadraticBezierTo(0, -size2 * 0.04, -size2 * 0.5, 0)
      ..close(), starPaint);
    canvas.drawCircle(Offset.zero, size2 * 0.06, Paint()..color = Color.fromRGBO(255, 255, 255, alpha));
    canvas.restore();
  }

  @override
  bool shouldRepaint(covariant _CommunicationPainter old) => old.t != t;
}
