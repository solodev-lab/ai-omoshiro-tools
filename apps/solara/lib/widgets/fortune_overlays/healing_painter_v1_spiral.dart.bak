import 'dart:math' as math;
import 'dart:ui' as ui;
import 'package:flutter/material.dart';
import '_common.dart';

/// 癒し: 花びらと光の粒が下から上へ螺旋を描いて舞い上がる。
/// 多彩な緑色のパレットで森・新緑・苔・翡翠を重ね合わせる。
class HealingPainterBuilder extends FortunePainterBuilder {
  final _rng = math.Random();
  late final List<_Petal> _petals;
  late final List<_LightMote> _motes;
  late final List<_Sparkle> _sparkles;

  static const _petalCount = 55;
  static const _moteCount = 85;
  static const _sparkleCount = 22;

  HealingPainterBuilder() {
    _petals = _buildPetals();
    _motes = _buildMotes();
    _sparkles = _buildSparkles();
  }

  @override
  CustomPainter buildPainter(double t) => _HealingPainter(
    t: t, petals: _petals, motes: _motes, sparkles: _sparkles,
  );

  List<_Petal> _buildPetals() {
    const palettes = <_PetalPalette>[
      // Fresh mint
      _PetalPalette(
        highlight: Color(0xFFF0FFF4), main: Color(0xFF86E6A8),
        shadow: Color(0xFF1F6038), rim: Color(0xFFCAF5D8), vein: Color(0xFF3E8A5A),
      ),
      // Emerald
      _PetalPalette(
        highlight: Color(0xFFE0FFEA), main: Color(0xFF3FCC78),
        shadow: Color(0xFF0C4024), rim: Color(0xFFA8EBC0), vein: Color(0xFF1E7E44),
      ),
      // Sage
      _PetalPalette(
        highlight: Color(0xFFF5FAEE), main: Color(0xFFA8C68A),
        shadow: Color(0xFF455A30), rim: Color(0xFFDCE8C6), vein: Color(0xFF6E8B55),
      ),
      // Forest
      _PetalPalette(
        highlight: Color(0xFFCCE8D2), main: Color(0xFF3A8058),
        shadow: Color(0xFF0A2E1A), rim: Color(0xFF6EAA88), vein: Color(0xFF1A4A2E),
      ),
      // Moss
      _PetalPalette(
        highlight: Color(0xFFEAF5D8), main: Color(0xFF708A48),
        shadow: Color(0xFF2A3A18), rim: Color(0xFFB8D090), vein: Color(0xFF45602C),
      ),
      // Teal green
      _PetalPalette(
        highlight: Color(0xFFE0FFF5), main: Color(0xFF4CBFA5),
        shadow: Color(0xFF0F4840), rim: Color(0xFFA8E8D8), vein: Color(0xFF1E7068),
      ),
      // Chartreuse / lime
      _PetalPalette(
        highlight: Color(0xFFF5FFD0), main: Color(0xFFBCE560),
        shadow: Color(0xFF4A6008), rim: Color(0xFFE2F2A0), vein: Color(0xFF708E28),
      ),
      // Jade
      _PetalPalette(
        highlight: Color(0xFFD8F5E4), main: Color(0xFF5FB888),
        shadow: Color(0xFF15482E), rim: Color(0xFFA0D6B4), vein: Color(0xFF2A7048),
      ),
    ];

    final list = <_Petal>[];
    for (var i = 0; i < _petalCount; i++) {
      list.add(_Petal(
        centerXRatio: 0.1 + _rng.nextDouble() * 0.8,
        spiralRadiusStart: 0.02 + _rng.nextDouble() * 0.05,
        spiralRadiusEnd: 0.10 + _rng.nextDouble() * 0.18,
        spiralSpeed: (0.5 + _rng.nextDouble() * 0.9) * (_rng.nextBool() ? 1 : -1),
        spiralPhase: _rng.nextDouble() * math.pi * 2,
        riseSpeed: 0.85 + _rng.nextDouble() * 0.5,
        startYOffset: 0.02 + _rng.nextDouble() * 0.35,
        size: 14.0 + math.pow(_rng.nextDouble(), 1.8).toDouble() * 38.0,
        aspect: 0.32 + _rng.nextDouble() * 0.22,
        palette: palettes[_rng.nextInt(palettes.length)],
        rotation: _rng.nextDouble() * math.pi * 2,
        rotSpeed: (_rng.nextDouble() - 0.5) * 2.0,
        tiltSpeed: 1.5 + _rng.nextDouble() * 2.2,
        tiltPhase: _rng.nextDouble() * math.pi * 2,
        delay: _rng.nextDouble() * 0.55,
      ));
    }
    return list;
  }

  List<_LightMote> _buildMotes() {
    final list = <_LightMote>[];
    for (var i = 0; i < _moteCount; i++) {
      list.add(_LightMote(
        centerXRatio: _rng.nextDouble(),
        spiralRadius: 0.03 + _rng.nextDouble() * 0.18,
        spiralSpeed: (0.6 + _rng.nextDouble() * 1.1) * (_rng.nextBool() ? 1 : -1),
        spiralPhase: _rng.nextDouble() * math.pi * 2,
        riseSpeed: 0.9 + _rng.nextDouble() * 0.6,
        startYOffset: 0.05 + _rng.nextDouble() * 0.40,
        size: 1.6 + _rng.nextDouble() * 3.8,
        twinklePhase: _rng.nextDouble() * math.pi * 2,
        twinkleSpeed: 2.0 + _rng.nextDouble() * 2.5,
        hue: _rng.nextDouble(),
        delay: _rng.nextDouble() * 0.55,
      ));
    }
    return list;
  }

  List<_Sparkle> _buildSparkles() {
    final list = <_Sparkle>[];
    for (var i = 0; i < _sparkleCount; i++) {
      list.add(_Sparkle(
        xRatio: _rng.nextDouble(),
        yRatio: _rng.nextDouble(),
        size: 8 + _rng.nextDouble() * 18,
        twinklePhase: _rng.nextDouble() * math.pi * 2,
        twinkleSpeed: 1.8 + _rng.nextDouble() * 2.2,
        hue: _rng.nextDouble(),
        delay: _rng.nextDouble() * 0.5,
      ));
    }
    return list;
  }
}

class _PetalPalette {
  final Color highlight, main, shadow, rim, vein;
  const _PetalPalette({
    required this.highlight, required this.main, required this.shadow,
    required this.rim, required this.vein,
  });
}

class _Petal {
  final double centerXRatio;
  final double spiralRadiusStart, spiralRadiusEnd;
  final double spiralSpeed, spiralPhase;
  final double riseSpeed, startYOffset;
  final double size, aspect;
  final _PetalPalette palette;
  final double rotation, rotSpeed, tiltSpeed, tiltPhase;
  final double delay;
  _Petal({
    required this.centerXRatio,
    required this.spiralRadiusStart, required this.spiralRadiusEnd,
    required this.spiralSpeed, required this.spiralPhase,
    required this.riseSpeed, required this.startYOffset,
    required this.size, required this.aspect, required this.palette,
    required this.rotation, required this.rotSpeed,
    required this.tiltSpeed, required this.tiltPhase,
    required this.delay,
  });
}

class _LightMote {
  final double centerXRatio, spiralRadius, spiralSpeed, spiralPhase;
  final double riseSpeed, startYOffset, size;
  final double twinklePhase, twinkleSpeed, hue, delay;
  _LightMote({
    required this.centerXRatio, required this.spiralRadius,
    required this.spiralSpeed, required this.spiralPhase,
    required this.riseSpeed, required this.startYOffset, required this.size,
    required this.twinklePhase, required this.twinkleSpeed,
    required this.hue, required this.delay,
  });
}

class _Sparkle {
  final double xRatio, yRatio, size, twinklePhase, twinkleSpeed, hue, delay;
  _Sparkle({
    required this.xRatio, required this.yRatio, required this.size,
    required this.twinklePhase, required this.twinkleSpeed,
    required this.hue, required this.delay,
  });
}

class _HealingPainter extends CustomPainter {
  final double t;
  final List<_Petal> petals;
  final List<_LightMote> motes;
  final List<_Sparkle> sparkles;
  _HealingPainter({required this.t, required this.petals, required this.motes, required this.sparkles});

  // 多彩な緑のグラデ色相バンク
  static const _greens = <Color>[
    Color(0xFF86E6A8), // fresh mint
    Color(0xFF3FCC78), // emerald
    Color(0xFFA8C68A), // sage
    Color(0xFF3A8058), // forest
    Color(0xFF708A48), // moss
    Color(0xFF4CBFA5), // teal green
    Color(0xFFBCE560), // chartreuse
    Color(0xFF5FB888), // jade
  ];

  Color _greenHue(double h) {
    final idx = (h * _greens.length).clamp(0.0, _greens.length - 1.0);
    final i = idx.floor();
    final f = idx - i;
    final a = _greens[i];
    final b = _greens[(i + 1) % _greens.length];
    return Color.lerp(a, b, f)!;
  }

  @override
  void paint(Canvas canvas, Size size) {
    // 背景: 下から濃緑→上に新緑〜翡翠の空気感
    final bgAlpha = stageAlpha(t, fadeIn: 0.12, hold: 0.60, fadeOut: 0.28);
    if (bgAlpha > 0) {
      canvas.drawRect(Offset.zero & size, Paint()
        ..shader = ui.Gradient.linear(
          Offset(size.width / 2, size.height),
          Offset(size.width / 2, 0),
          [
            Color.fromRGBO(30, 70, 45, 0.38 * bgAlpha),
            Color.fromRGBO(90, 170, 110, 0.30 * bgAlpha),
            Color.fromRGBO(180, 230, 170, 0.22 * bgAlpha),
            const Color(0x00000000),
          ],
          [0.0, 0.35, 0.75, 1.0],
        ));
    }

    // 上部のオーロラ風緑色の帯
    _drawAuroraBand(canvas, size, bgAlpha);

    // 光の粒（奥、上昇）
    for (final m in motes) { _drawMote(canvas, m, size); }

    // 花びら（上昇＋螺旋）
    for (final p in petals) { _drawPetal(canvas, p, size); }

    // スパークル（前面）
    for (final s in sparkles) { _drawSparkle(canvas, s, size); }
  }

  void _drawAuroraBand(Canvas canvas, Size size, double bgAlpha) {
    if (bgAlpha <= 0) return;
    final bandTop = size.height * 0.03;
    final bandBottom = size.height * 0.35;
    final rect = Rect.fromLTRB(0, bandTop, size.width, bandBottom);

    final phase = t * math.pi * 0.8;
    final hue1 = Color.lerp(
      const Color(0xFF5FD8A0), const Color(0xFF88E8B0), (math.sin(phase) + 1) / 2,
    )!;
    final hue2 = Color.lerp(
      const Color(0xFFBCE590), const Color(0xFF6FC488), (math.cos(phase * 0.7) + 1) / 2,
    )!;

    canvas.drawRect(rect, Paint()
      ..shader = ui.Gradient.linear(
        Offset(0, bandTop), Offset(0, bandBottom),
        [
          hue1.withValues(alpha: 0.32 * bgAlpha),
          hue2.withValues(alpha: 0.20 * bgAlpha),
          const Color(0x00000000),
        ],
        [0.0, 0.5, 1.0],
      )
      ..blendMode = BlendMode.plus);
  }

  // 螺旋運動: 下から上へ昇りながら、円の周りをぐるぐる回る。
  // 下は遅く、上に行くほど加速（easeInCubic的な運動）。
  Offset _spiralPos(
    Size size, {
    required double centerXRatio,
    required double radiusStartRatio,
    required double radiusEndRatio,
    required double spiralSpeed,
    required double spiralPhase,
    required double riseSpeed,
    required double startYOffsetRatio,
    required double lt,
  }) {
    // 縦方向: startY(画面下外)→endY(画面上外)
    // 線形(前半からしっかり動く) と easeInQuad(後半で加速) の 50/50 ブレンド。
    // 0.87倍スケール = overlay duration 4.0s に対して上昇時間を約4.6s相当に
    // 引き延ばし（体感 +0.6s 長い上昇）。lt=1.0 時点で進捗 0.87 となり、
    // fadeOut中も昇り続ける。
    const timeScale = 0.87;
    final startY = size.height * (1.08 + startYOffsetRatio);
    final endY = -size.height * 0.15;
    final curve = (0.5 * lt + 0.5 * lt * lt) * timeScale;
    final rise = (curve * riseSpeed).clamp(0.0, 1.0);
    final y = startY + (endY - startY) * rise;

    // 半径は徐々に広がる
    final radiusRatio = radiusStartRatio +
        (radiusEndRatio - radiusStartRatio) * easeOutCubic(lt);
    final radius = radiusRatio * size.width;

    final angle = spiralPhase + lt * spiralSpeed * math.pi * 2;
    final cx = centerXRatio * size.width;
    final x = cx + math.cos(angle) * radius;
    return Offset(x, y);
  }

  void _drawPetal(Canvas canvas, _Petal p, Size size) {
    final lt = ((t - p.delay) / (1.0 - p.delay)).clamp(0.0, 1.0);
    if (lt <= 0) return;
    final alpha = stageAlpha(lt, fadeIn: 0.10, hold: 0.70, fadeOut: 0.20);
    if (alpha <= 0) return;

    final pos = _spiralPos(
      size,
      centerXRatio: p.centerXRatio,
      radiusStartRatio: p.spiralRadiusStart,
      radiusEndRatio: p.spiralRadiusEnd,
      spiralSpeed: p.spiralSpeed,
      spiralPhase: p.spiralPhase,
      riseSpeed: p.riseSpeed,
      startYOffsetRatio: p.startYOffset,
      lt: lt,
    );
    if (pos.dy < -size.height * 0.2 || pos.dy > size.height * 1.2) return;

    // 3D風傾き
    final tiltCos = math.cos(p.tiltPhase + lt * p.tiltSpeed * math.pi * 2);
    final faceVis = tiltCos.abs().clamp(0.25, 1.0);
    final isBackside = tiltCos < 0;

    final rot = p.rotation + p.rotSpeed * lt * math.pi;

    canvas.save();
    canvas.translate(pos.dx, pos.dy);
    canvas.rotate(rot);

    final s = p.size;
    final w = s * p.aspect;
    final pal = p.palette;

    // 後光
    canvas.drawOval(
      Rect.fromCenter(center: Offset.zero, width: w * 2.4, height: s * 1.5),
      Paint()
        ..shader = ui.Gradient.radial(Offset.zero, s * 0.75, [
          pal.main.withValues(alpha: 0.36 * alpha),
          pal.main.withValues(alpha: 0.12 * alpha),
          const Color(0x00000000),
        ], [0.0, 0.55, 1.0])
        ..blendMode = BlendMode.plus,
    );

    canvas.save();
    canvas.scale(faceVis, 1.0);

    final path = _buildPetalPath(s, w);

    canvas.drawPath(path, Paint()
      ..shader = ui.Gradient.linear(
        Offset(0, -s * 0.4), Offset(0, s * 0.4),
        isBackside
            ? [
                pal.shadow.withValues(alpha: 0.85 * alpha),
                pal.main.withValues(alpha: 0.65 * alpha),
                pal.shadow.withValues(alpha: 0.75 * alpha),
              ]
            : [
                pal.highlight.withValues(alpha: alpha),
                pal.main.withValues(alpha: alpha),
                pal.shadow.withValues(alpha: 0.88 * alpha),
              ],
        const [0.0, 0.5, 1.0],
      ));

    if (!isBackside) {
      canvas.drawPath(path, Paint()
        ..shader = ui.Gradient.radial(
          Offset(-w * 0.2, -s * 0.12), s * 0.55,
          [
            Color.fromRGBO(255, 255, 255, 0.55 * alpha),
            const Color(0x00FFFFFF),
          ],
          [0.0, 1.0],
        )
        ..blendMode = BlendMode.plus);
    }

    if (!isBackside && faceVis > 0.5) {
      canvas.drawLine(
        Offset(0, -s * 0.42),
        Offset(0, s * 0.42),
        Paint()
          ..color = pal.vein.withValues(alpha: 0.40 * alpha)
          ..strokeWidth = math.max(0.6, s * 0.01),
      );
    }

    canvas.drawPath(path, Paint()
      ..style = PaintingStyle.stroke
      ..strokeWidth = math.max(0.6, s * 0.012)
      ..color = (isBackside ? pal.shadow : pal.rim).withValues(alpha: 0.65 * alpha));

    canvas.restore();
    canvas.restore();
  }

  Path _buildPetalPath(double length, double width) {
    final path = Path();
    final l = length * 0.5;
    final w = width * 0.5;
    path.moveTo(0, -l);
    path.cubicTo(w * 1.3, -l * 0.5, w * 1.05, l * 0.55, 0, l);
    path.cubicTo(-w * 1.05, l * 0.55, -w * 1.3, -l * 0.5, 0, -l);
    path.close();
    return path;
  }

  void _drawMote(Canvas canvas, _LightMote m, Size size) {
    final lt = ((t - m.delay) / (1.0 - m.delay)).clamp(0.0, 1.0);
    if (lt <= 0) return;
    final fadeEnv = stageAlpha(lt, fadeIn: 0.18, hold: 0.60, fadeOut: 0.22);
    if (fadeEnv <= 0) return;

    final pos = _spiralPos(
      size,
      centerXRatio: m.centerXRatio,
      radiusStartRatio: m.spiralRadius * 0.3,
      radiusEndRatio: m.spiralRadius,
      spiralSpeed: m.spiralSpeed,
      spiralPhase: m.spiralPhase,
      riseSpeed: m.riseSpeed,
      startYOffsetRatio: m.startYOffset,
      lt: lt,
    );
    if (pos.dy < -40 || pos.dy > size.height + 40) return;

    final tw = (math.sin(m.twinklePhase + lt * m.twinkleSpeed * math.pi * 2) + 1) / 2;
    final alpha = fadeEnv * (0.35 + tw * 0.65);
    final color = _greenHue(m.hue);
    final size2 = m.size * (0.7 + tw * 0.5);

    canvas.drawCircle(pos, size2 * 1.7, Paint()
      ..shader = ui.Gradient.radial(pos, size2 * 1.7, [
        color.withValues(alpha: 0.60 * alpha),
        color.withValues(alpha: 0.20 * alpha),
        const Color(0x00000000),
      ], [0.0, 0.5, 1.0])
      ..blendMode = BlendMode.plus);
    canvas.drawCircle(pos, size2, Paint()
      ..color = Color.lerp(Colors.white, color, 0.25)!
          .withValues(alpha: alpha));
  }

  void _drawSparkle(Canvas canvas, _Sparkle sp, Size size) {
    final lt = ((t - sp.delay) / (1.0 - sp.delay)).clamp(0.0, 1.0);
    if (lt <= 0) return;
    final fadeEnv = stageAlpha(lt, fadeIn: 0.18, hold: 0.55, fadeOut: 0.27);
    if (fadeEnv <= 0) return;

    final pos = Offset(size.width * sp.xRatio, size.height * sp.yRatio);
    final tw = (math.sin(sp.twinklePhase + lt * sp.twinkleSpeed * math.pi * 2) + 1) / 2;
    final alpha = fadeEnv * (0.35 + tw * 0.65);
    final color = _greenHue(sp.hue);
    final size2 = sp.size * (0.7 + tw * 0.6);

    canvas.save();
    canvas.translate(pos.dx, pos.dy);
    canvas.drawCircle(Offset.zero, size2 * 0.7, Paint()
      ..shader = ui.Gradient.radial(Offset.zero, size2 * 0.7, [
        color.withValues(alpha: 0.55 * alpha),
        color.withValues(alpha: 0.18 * alpha),
        const Color(0x00000000),
      ], [0.0, 0.5, 1.0])
      ..blendMode = BlendMode.plus);
    final starPaint = Paint()..color = color.withValues(alpha: alpha)..blendMode = BlendMode.plus;
    canvas.drawPath(Path()
      ..moveTo(0, -size2 * 0.5)
      ..quadraticBezierTo(size2 * 0.04, 0, 0, size2 * 0.5)
      ..quadraticBezierTo(-size2 * 0.04, 0, 0, -size2 * 0.5)
      ..close(), starPaint);
    canvas.drawPath(Path()
      ..moveTo(-size2 * 0.5, 0)
      ..quadraticBezierTo(0, size2 * 0.04, size2 * 0.5, 0)
      ..quadraticBezierTo(0, -size2 * 0.04, -size2 * 0.5, 0)
      ..close(), starPaint);
    canvas.drawCircle(Offset.zero, size2 * 0.06, Paint()..color = Color.fromRGBO(255, 255, 255, alpha));
    canvas.restore();
  }

  @override
  bool shouldRepaint(covariant _HealingPainter old) => old.t != t;
}
